    "react-native-mock-render": "^0.1.9",
    "react-test-renderer": "18.2.0",
    "redux-logger": "^3.0.6",
    "redux-mock-store": "^1.5.4",
    "redux-saga-test-plan": "^4.0.0-rc.3"
  },
  "rnpm": {
    "assets": [
      "./assets/fonts/",
      "./config/fonts/",
      "./config/images/"
