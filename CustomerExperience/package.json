    "react-native-gesture-handler": "^1.10.3",
    "react-native-i18n": "^2.0.15",
    "react-native-indicators": "^0.17.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-linear-gradient": "^2.5.6",
    "react-native-localize": "^2.0.3",
    "react-native-material-textfield": "git+https://github.com/javarahulsharma/react-native-material-textfield.git",
    "react-native-material-textfield-axel": "^0.14.0",
    "react-native-modal": "^13.0.0",
    "react-native-notifications": "3.5.0",
    "react-native-pell-rich-editor": "^1.8.8",
    "react-native-phone-number-input": "^2.1.0",
    "react-native-pie": "^1.1.2",
    "react-native-read-more-text": "^1.1.2",
    "react-native-reanimated": "^1.7.0",
    "react-native-redux-connectivity": "^0.2.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "4.5.0",
    "react-native-safe-area-view": "^1.1.1",
    "react-native-screens": "3.1.1",
    "react-native-simple-radio-button": "^2.7.4",
    "react-native-svg": "^12.1.1",
    "react-native-swipe-gestures": "^1.0.5",
    "react-native-swiper": "^1.6.0-rc.3",
    "react-native-tab-view": "^2.15.2",
    "react-native-toast-message": "^2.2.1",
    "react-native-unimodules": "^0.14.10",
    "react-native-vector-icons": "^7.0.0",
    "react-native-webview": "^11.13.0",
    "react-navigation": "^4.4.0",
    "react-navigation-redux-helpers": "^2.0.9",
    "react-redux": "^7.2.0",
    "reanimated-bottom-sheet": "^1.0.0-alpha.22",
    "redux": "^4.0.5",
    "redux-api-middleware": "^3.2.1",
    "redux-devtools-extension": "^2.13.8",
    "redux-saga": "^1.1.3",
    "rn-fetch-blob": "^0.12.0",
    "tslib": "^2.0.3",
    "typescript": "^5.3.3",
    "victory-native": "^35.0.1",
    "xdate": "^0.8.2"
  },
  "devDependencies": {
    "@babel/core": "7.10.4",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/runtime": "7.10.4",
    "@react-native-community/cli": "^6.0.0",
    "@react-native-community/cli-platform-android": "^6.0.0",
    "@react-native-community/cli-platform-ios": "^6.0.0",
    "@react-native-community/eslint-config": "^2.0.0",
    "@rnx-kit/align-deps": "^2.2.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^12.4.3",
    "babel-jest": "29.7.0",
    "depcheck": "^1.4.3",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.2",
    "eslint": "^7.18.0",
    "jest": "29.7.0",
    "jest-cli": "29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "jsdom": "^16.3.0",
    "metro-react-native-babel-preset": "^0.67.0",
    "react-native-clean-project": "^4.0.3",
    "react-native-mock": "^0.3.1",
    "react-native-mock-render": "^0.1.9",
    "react-native-svg-transformer": "^1.5.0",
    "react-test-renderer": "17.0.2",
    "redux-logger": "^3.0.6",
    "redux-mock-store": "^1.5.4",
    "redux-saga-test-plan": "^4.0.0-rc.3"
  },
  "rnpm": {
    "assets": [
      "./assets/fonts/",
      "./config/fonts/",
      "./config/images/"
    ]
  },
  "rnx-kit": {
    "kitType": "app",
    "alignDeps": {
      "requirements": [
        "react-native@0.67"
      ],
      "capabilities": [
        "animation",
        "babel-preset-react-native",
        "checkbox",
        "community/cli",
