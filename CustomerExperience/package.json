{
  "name": "CustomerExperience",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:clean": "cd android && ./gradlew clean --stacktrace && cd ..",
    "android:build": "cd android && ./gradlew build --stacktrace && cd ..",
    "android:cleanBuild": "cd android && ./gradlew clean  --stacktrace && ./gradlew build  --stacktrace && cd ..",
    "android:cleanBuildAssemble": "cd android && ./gradlew clean build assembleDebug --stacktrace && cd ..",
    "ios:archive": "NODE_OPTIONS=--openssl-legacy-provider xcodebuild -workspace CustomerExperience.xcworkspace -scheme CustomerExperience -configuration Release -archivePath ./build/CustomerExperience.xcarchive archive",
    "ios:archive2": "NODE_OPTIONS=--openssl-legacy-provider xcodebuild -workspace CustomerExperience.xcworkspace -scheme CustomerExperience -configuration Release -archivePath ./build/CustomerExperience.xcarchive archive",
    "ios": "NODE_OPTIONS=--openssl-legacy-provider react-native run-ios",
    "start": "NODE_OPTIONS=--openssl-legacy-provider react-native start",
    "start:resetCache": "react-native start --reset-cache",
    "test": "NODE_OPTIONS=--openssl-legacy-provider jest -u",
    "test:watch": "NODE_OPTIONS=--openssl-legacy-provider jest --watch",
    "test:coverage": "NODE_OPTIONS=--openssl-legacy-provider jest --coverage -u",
    "postinstall": "patch-package",
    "check-deps": "rnx-align-deps",
    "fix-deps": "rnx-align-deps --write",
    "ios:pod-reinstall": "cd ios && pod deintegrate && pod cache clean --all && arch -x86_64 pod install && cd ..",
    "android:debug-bundle": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "android:appBundle": "NODE_OPTIONS=--openssl-legacy-provider react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/app.bundle --assets-dest android/app/src/main/res",
    "android:debug-bundleNew": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "android:debug-bundle-assetRemove": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/app.bundle --assets-dest android/app/src/main/res/ && cd android && ./gradlew assembleDebug && cd .. && rm -rf android/app/src/main/res/drawable-* && rm -rf android/app/src/main/res/raw/* && rm -rf android/app/src/main/assets/*",
    "reset_": "rm -rf node_modules && yarn cache clean && yarn && yarn cache clean",
    "clean_": "yarn cache clean",
    "watchman:clean": "watchman watch-del-all",
    "ios:pod-install": "cd ios && arch -x86_64 pod install && cd ..",
    "test:jest-clear": "NODE_OPTIONS=--openssl-legacy-provider jest --clearCache",
    "test:unit": "NODE_OPTIONS=--openssl-legacy-provider jest --testPathPattern=app/testcases/unit_test",
    "test:widget": "NODE_OPTIONS=--openssl-legacy-provider jest --testPathPattern=app/testcases/widget_test",
    "test:component": "NODE_OPTIONS=--openssl-legacy-provider jest --testPathPattern=app/testcases/component_test -u",
    "test:singleFile": "NODE_OPTIONS=--openssl-legacy-provider jest --testPathPattern=app/components/closedloop/takeaction/SendEmail.test.js -u",
    "test:singleFileCoverageOld": "NODE_OPTIONS=--openssl-legacy-provider jest --coverage --testPathPattern=app/routes/CommonScreen.test.js.test.js -u",
    "test:singleFileCoverage": "NODE_OPTIONS=--openssl-legacy-provider jest --collectCoverageFrom=\"<rootDir>/app/**/*.{js,jsx}\" --testPathPattern=app/components/view/CalendarScreen.test.js -u",
    "test:singleDirectoryCoverage": "NODE_OPTIONS=--openssl-legacy-provider jest --coverage --testPathPattern=app/components/closedloop/",
    "android:go": "rm -rf node_modules && yarn cache clean && yarn && yarn cache clean && cd android && ./gradlew clean --stacktrace && cd .. && react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res && react-native run-android"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.15.16",
    "@react-native-clipboard/clipboard": "1.11.2",
    "@react-native-community/art": "^1.2.0",
    "@react-native-community/netinfo": "9.4.1",
    "@react-native-firebase/app": "10.8.1",
    "@react-native-firebase/dynamic-links": "10.8.1",
    "@react-native-firebase/messaging": "10.8.1",
    "@react-navigation/core": "^5.16.1",
