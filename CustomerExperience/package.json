{
  "name": "CustomerExperience",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "clean-android": "cd android && ./gradlew clean && cd ..",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "patch-package",
    "check-dependencies": "rnx-align-deps",
    "fix-dependencies": "rnx-align-deps --write",
    "ios-pod-reinstall": "cd ios && pod deintegrate && pod cache clean --all && arch -x86_64 pod install && cd ..",
    "gen_android_jsbundle": "npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "reset_": "rm -rf node_modules && yarn cache clean && yarn",
    "clean_": "yarn cache clean",
    "ios-pod-install": "cd ios && arch -x86_64 pod install && cd ..",
    "test:unit": "jest --testPathPattern=app/testcases/unit_test",
    "test:widget": "jest --testPathPattern=app/testcases/widget_test",
    "test:component": "jest --testPathPattern=app/testcases/component_test"
  },
  "dependencies": {
    "@gregfrench/react-native-wheel-picker": "^1.2.3",
