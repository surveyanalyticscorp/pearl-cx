<?xml version="1.0" encoding="utf-8"?>

    <LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/background_inverted"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="40dp"
            android:text="@string/app_name"
            android:textColor="@color/md_white_1000"
            android:textStyle="bold"
            android:textSize="30sp"/>

        <com.questionpro.whitelabelapps.views.CustomEditText
            android:id="@+id/emailAddress"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="30dp"
            android:background="#FFFFFF"
            android:ems="10"
            android:hint="@string/email_address"
            android:imeOptions="actionNext"
            android:inputType="textEmailAddress"
            android:padding="10dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <com.questionpro.whitelabelapps.views.CustomEditText
                android:id="@+id/password"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="#FFFFFF"
                android:ems="10"
                android:hint="@string/password"
                android:imeOptions="actionNext"
                android:inputType="textPassword"
                android:padding="10dp" />


            <ImageButton
                android:id="@+id/showPasswordCheck"
                android:layout_width="30dp"
                android:layout_height="45dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:background="@color/footer_background_color"
                android:scaleType="center"
                android:src="@drawable/show_password_icon" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/companyCodeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <com.questionpro.whitelabelapps.views.CustomEditText
                android:id="@+id/companyCode"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="#FFFFFF"
                android:ems="10"
                android:hint="@string/company_code"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:padding="10dp" />

            <ImageButton
                android:id="@+id/whatIsCompanyCode"
                android:layout_width="30dp"
                android:layout_height="45dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:background="@color/footer_background_color"
                android:src="@drawable/what_is_icon" />
        </RelativeLayout>

        <com.questionpro.whitelabelapps.views.CustomTextView
            android:id="@+id/invalidEmailPassswordText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:text="@string/invalid_email_password"
            android:textColor="@color/md_white_1000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="invisible" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.questionpro.whitelabelapps.views.CustomButton
                android:id="@+id/signInButton"
                style="@style/AppTheme.LoginButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="0dp"
                android:text="@string/sign_in" />

            <ProgressBar
                android:id="@+id/signInProgress"
                style="@android:style/Widget.ProgressBar.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginRight="20dp"
                android:elevation="7dp"
                android:foregroundTint="@color/colorAccent"
                android:visibility="invisible" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="right"
            android:orientation="vertical">

            <com.questionpro.whitelabelapps.views.CustomTextView
                android:id="@+id/forgotPasswordButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="5dp"
                android:paddingTop="10dp"
                android:text="@string/forgot_password"
                android:textColor="@color/md_white_1000"
                android:textSize="@dimen/ms_text_size" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/joinNowLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="5dp"
            android:paddingTop="10dp"
            android:layout_marginTop="10dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal">
            <com.questionpro.whitelabelapps.views.CustomTextView
                android:id="@+id/newMemberText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/not_a_member_yet"
                android:textColor="@color/colorAccent"
                android:textSize="16sp"
                />
            <com.questionpro.whitelabelapps.views.CustomTextView
                android:id="@+id/joinNowButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/join_now"
                android:layout_marginLeft="2dp"
                android:textColor="@color/colorAccent"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <ImageButton
            android:layout_width="@dimen/login_bottom_logo"
            android:layout_height="@dimen/login_bottom_logo"
            android:scaleType="centerInside"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="0dp"
            android:background="@drawable/login_bottom_image"/>

    </LinearLayout>

