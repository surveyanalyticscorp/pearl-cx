<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="10dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/msIcon"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/ms_icon_size"
            android:layout_centerInParent="true"
            android:adjustViewBounds="true"
            android:clickable="false"
            android:scaleType="fitCenter"
            android:src="@drawable/testing" />

        <ImageView
            android:id="@+id/ms_divider_line"
            android:layout_width="@dimen/ms_divider_line_width"
            android:layout_height="3dp"
            android:layout_below="@+id/msIcon"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="40dp"
            android:background="@color/ms_divider_line_color"
            android:visibility="gone"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal|bottom"
        android:orientation="vertical">

        <com.questionpro.views.CustomTextView
            android:id="@+id/msTitle"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginBottom="10dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:maxLines="2"
            android:text="Get Notified dalhlh  adhlahd lhdlh als"
            android:textAlignment="center"
            android:textColor="@color/ms_title_text_color"
            android:textSize="@dimen/ms_title_size"
            android:textStyle="bold" />


        <com.questionpro.views.CustomTextView
            android:id="@+id/msText"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:ellipsize="end"
            android:layout_marginLeft="25dp"
            android:layout_marginRight="25dp"
            android:gravity="center_horizontal"
            android:maxLines="3"
            android:text="Push notifications of when respondents take your survey or alerts when specific response criterion are met."
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/ms_text_size"
            android:textStyle="normal" />
    </LinearLayout>

</LinearLayout>