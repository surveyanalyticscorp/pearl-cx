ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Alamofire-framework" "${PODS_CONFIGURATION_BUILD_DIR}/AppAuth-framework" "${PODS_CONFIGURATION_BUILD_DIR}/DoubleConversion-framework" "${PODS_CONFIGURATION_BUILD_DIR}/FMDB-framework" "${PODS_CONFIGURATION_BUILD_DIR}/Folly-framework" "${PODS_CONFIGURATION_BUILD_DIR}/GTMAppAuth-framework" "${PODS_CONFIGURATION_BUILD_DIR}/GTMSessionFetcher-framework" "${PODS_CONFIGURATION_BUILD_DIR}/RNDeviceInfo-framework" "${PODS_CONFIGURATION_BUILD_DIR}/RNFS-framework" "${PODS_CONFIGURATION_BUILD_DIR}/RNGestureHandler-framework" "${PODS_CONFIGURATION_BUILD_DIR}/RNI18n-framework" "${PODS_CONFIGURATION_BUILD_DIR}/RNReanimated-framework" "${PODS_CONFIGURATION_BUILD_DIR}/RNVectorIcons-framework" "${PODS_CONFIGURATION_BUILD_DIR}/ReachabilitySwift-framework" "${PODS_CONFIGURATION_BUILD_DIR}/React-framework" "${PODS_CONFIGURATION_BUILD_DIR}/glog-framework" "${PODS_CONFIGURATION_BUILD_DIR}/react-native-document-picker-framework" "${PODS_CONFIGURATION_BUILD_DIR}/react-native-material-kit-framework" "${PODS_CONFIGURATION_BUILD_DIR}/react-native-webview-framework" "${PODS_CONFIGURATION_BUILD_DIR}/yoga-framework" "${PODS_ROOT}/GoogleSignIn/Frameworks"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Alamofire-framework/Alamofire.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/AppAuth-framework/AppAuth.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/DoubleConversion-framework/DoubleConversion.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/FMDB-framework/FMDB.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/Folly-framework/folly.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/GTMAppAuth-framework/GTMAppAuth.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/GTMSessionFetcher-framework/GTMSessionFetcher.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/RNDeviceInfo-framework/RNDeviceInfo.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/RNFS-framework/RNFS.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/RNGestureHandler-framework/RNGestureHandler.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/RNI18n-framework/RNI18n.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/RNReanimated-framework/RNReanimated.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/RNVectorIcons-framework/RNVectorIcons.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/ReachabilitySwift-framework/Reachability.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/React-framework/React.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/glog-framework/glog.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/react-native-document-picker-framework/react_native_document_picker.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/react-native-material-kit-framework/react_native_material_kit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/react-native-webview-framework/react_native_webview.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/yoga-framework/yoga.framework/Headers" "${PODS_ROOT}/Headers/Public" "${PODS_ROOT}/Headers/Public/AppAuth" "${PODS_ROOT}/Headers/Public/DoubleConversion" "${PODS_ROOT}/Headers/Public/FMDB" "${PODS_ROOT}/Headers/Public/GTMAppAuth" "${PODS_ROOT}/Headers/Public/GTMSessionFetcher" "${PODS_ROOT}/Headers/Public/GoogleAnalytics" "${PODS_ROOT}/Headers/Public/RNDeviceInfo" "${PODS_ROOT}/Headers/Public/RNFS" "${PODS_ROOT}/Headers/Public/RNGestureHandler" "${PODS_ROOT}/Headers/Public/RNI18n" "${PODS_ROOT}/Headers/Public/RNReanimated" "${PODS_ROOT}/Headers/Public/RNVectorIcons" "${PODS_ROOT}/Headers/Public/React" "${PODS_ROOT}/Headers/Public/glog" "${PODS_ROOT}/Headers/Public/react-native-document-picker" "${PODS_ROOT}/Headers/Public/react-native-material-kit" "${PODS_ROOT}/Headers/Public/react-native-webview" "${PODS_ROOT}/Headers/Public/yoga"
LD_RUNPATH_SEARCH_PATHS = $(inherited) '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/GoogleAnalytics/Libraries"
OTHER_LDFLAGS = $(inherited) -ObjC -l"GoogleAnalytics" -l"sqlite3" -l"stdc++" -l"z" -framework "Alamofire" -framework "AppAuth" -framework "CoreData" -framework "CoreGraphics" -framework "CoreTelephony" -framework "CoreText" -framework "DoubleConversion" -framework "FMDB" -framework "Foundation" -framework "GTMAppAuth" -framework "GTMSessionFetcher" -framework "GoogleSignIn" -framework "JavaScriptCore" -framework "LocalAuthentication" -framework "RNDeviceInfo" -framework "RNFS" -framework "RNGestureHandler" -framework "RNI18n" -framework "RNReanimated" -framework "RNVectorIcons" -framework "Reachability" -framework "React" -framework "SafariServices" -framework "Security" -framework "SystemConfiguration" -framework "UIKit" -framework "folly" -framework "glog" -framework "react_native_document_picker" -framework "react_native_material_kit" -framework "react_native_webview" -framework "yoga" -weak_framework "AuthenticationServices"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
