ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/GoogleSignIn/Frameworks"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/Headers/Public" "${PODS_ROOT}/Headers/Public/AppAuth" "${PODS_ROOT}/Headers/Public/DoubleConversion" "${PODS_ROOT}/Headers/Public/FMDB" "${PODS_ROOT}/Headers/Public/GTMAppAuth" "${PODS_ROOT}/Headers/Public/GTMSessionFetcher" "${PODS_ROOT}/Headers/Public/GoogleAnalytics" "${PODS_ROOT}/Headers/Public/RNDeviceInfo" "${PODS_ROOT}/Headers/Public/RNFS" "${PODS_ROOT}/Headers/Public/RNGestureHandler" "${PODS_ROOT}/Headers/Public/RNI18n" "${PODS_ROOT}/Headers/Public/RNReanimated" "${PODS_ROOT}/Headers/Public/RNVectorIcons" "${PODS_ROOT}/Headers/Public/React" "${PODS_ROOT}/Headers/Public/glog" "${PODS_ROOT}/Headers/Public/react-native-document-picker" "${PODS_ROOT}/Headers/Public/react-native-material-kit" "${PODS_ROOT}/Headers/Public/react-native-webview" "${PODS_ROOT}/Headers/Public/yoga"
LIBRARY_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Alamofire-library" "${PODS_CONFIGURATION_BUILD_DIR}/AppAuth-library" "${PODS_CONFIGURATION_BUILD_DIR}/DoubleConversion-library" "${PODS_CONFIGURATION_BUILD_DIR}/FMDB-library" "${PODS_CONFIGURATION_BUILD_DIR}/Folly-library" "${PODS_CONFIGURATION_BUILD_DIR}/GTMAppAuth-library" "${PODS_CONFIGURATION_BUILD_DIR}/GTMSessionFetcher-library" "${PODS_CONFIGURATION_BUILD_DIR}/RNDeviceInfo-library" "${PODS_CONFIGURATION_BUILD_DIR}/RNFS-library" "${PODS_CONFIGURATION_BUILD_DIR}/RNGestureHandler-library" "${PODS_CONFIGURATION_BUILD_DIR}/RNI18n-library" "${PODS_CONFIGURATION_BUILD_DIR}/RNReanimated-library" "${PODS_CONFIGURATION_BUILD_DIR}/RNVectorIcons-library" "${PODS_CONFIGURATION_BUILD_DIR}/ReachabilitySwift-library" "${PODS_CONFIGURATION_BUILD_DIR}/React-library" "${PODS_CONFIGURATION_BUILD_DIR}/glog-library" "${PODS_CONFIGURATION_BUILD_DIR}/react-native-document-picker-library" "${PODS_CONFIGURATION_BUILD_DIR}/react-native-material-kit-library" "${PODS_CONFIGURATION_BUILD_DIR}/react-native-webview-library" "${PODS_CONFIGURATION_BUILD_DIR}/yoga-library" "${PODS_ROOT}/GoogleAnalytics/Libraries"
OTHER_CFLAGS = $(inherited) -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/Alamofire-library/Alamofire.modulemap" -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/ReachabilitySwift-library/Reachability.modulemap"
OTHER_LDFLAGS = $(inherited) -ObjC -l"Alamofire-library" -l"AppAuth-library" -l"DoubleConversion-library" -l"FMDB-library" -l"Folly-library" -l"GTMAppAuth-library" -l"GTMSessionFetcher-library" -l"GoogleAnalytics" -l"RNDeviceInfo-library" -l"RNFS-library" -l"RNGestureHandler-library" -l"RNI18n-library" -l"RNReanimated-library" -l"RNVectorIcons-library" -l"ReachabilitySwift-library" -l"React-library" -l"glog-library" -l"react-native-document-picker-library" -l"react-native-material-kit-library" -l"react-native-webview-library" -l"sqlite3" -l"stdc++" -l"yoga-library" -l"z" -framework "CoreData" -framework "CoreGraphics" -framework "CoreTelephony" -framework "CoreText" -framework "Foundation" -framework "GoogleSignIn" -framework "JavaScriptCore" -framework "LocalAuthentication" -framework "SafariServices" -framework "Security" -framework "SystemConfiguration" -framework "UIKit" -weak_framework "AuthenticationServices"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/Alamofire-library/Alamofire.modulemap" -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/ReachabilitySwift-library/Reachability.modulemap"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
SWIFT_INCLUDE_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Alamofire-library" "${PODS_CONFIGURATION_BUILD_DIR}/ReachabilitySwift-library"
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
