{
  "name": "InterceptSDKExample",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "clean-install": "rm -rf node_modules package-lock.json && npm cache clean --force && npm install",
