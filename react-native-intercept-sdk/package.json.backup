{
  "name": "@questionpro/react-native-intercept-sdk",
  "version": "1.0.0",
  "description": "React Native SDK wrapper for QuestionPro Survey Intercept SDK",
  "main": "lib/commonjs/index.js",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index.ts",
  "scripts": {
    "prepare": "bob build",
    "build": "bob build",
    "test": "jest",
    "typescript": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{js,ts,tsx}\" --fix",
    "example": "cd example && npm start"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "survey",
    "intercept",
    "questionpro"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/questionpro/react-native-intercept-sdk.git"
  },
  "author": "QuestionPro <support@questionpro.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/questionpro/react-native-intercept-sdk/issues"
  },
  "homepage": "https://github.com/questionpro/react-native-intercept-sdk#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native-community/eslint-config": "^3.2.0",
    "@types/jest": "^29.5.5",
    "@types/react": "^18.2.21",
    "@types/react-native": "^0.72.2",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.72.4",
    "react-native-builder-bob": "^0.23.1",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "engines": {
    "node": ">= 16.0.0"
  },
  "packageManager": "npm@9.8.1",
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native-community"
    ]
  },
  "codegenConfig": {
    "name": "RNInterceptSdkSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  },

  "react-native": {
    "android": {
      "sourceDir": "../android",
      "packageImportPath": "com.questionpro.interceptsdk.InterceptSdkPackage"
    },
    "ios": {
      "podspecPath": "../react-native-intercept-sdk.podspec"
    }
  }
}
