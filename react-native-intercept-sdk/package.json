{
  "name": "@npm-questionpro/react-native-survey-intercept",
  "version": "0.1.5",
  "description": "React Native SDK wrapper for QuestionPro Survey Intercept SDK",
  "main": "lib/commonjs/index.js",
  "files": [
    "lib/",
    "android/src/",
    "android/build.gradle",
    "ios/*.{swift,m,h}",
    "src/",
    "react-native-survey-intercept.podspec",
    "README.md",
    "LICENSE"
  ],
  "types": "lib/typescript/index.d.ts",
  "source": "src/index.ts",
  "scripts": {
    "prepare": "bob build",
    "build": "bob build",
    "example": "cd example && npm start",
    "rebuild": "npm cache clean --force && npm install && npm run build"
  },
  "keywords": [
    "react-native",
    "questionpro",
    "survey",
    "intercept",
    "mobile-sdk",
    "typescript",
    "android",
    "ios"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/questionpro/react-native-survey-intercept.git"
  },
  "homepage": "https://github.com/questionpro/react-native-survey-intercept#readme",
  "author": "QuestionPro <datta.kunde@questionpro.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/react": "^18.0.24",
    "@types/react-native": "0.71.6",
    "react": "18.2.0",
    "react-native": "0.72.4",
    "react-native-builder-bob": "^0.20.0",
    "typescript": "^4.8.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0"
  },
  "react-native": {
    "android": {
      "sourceDir": "./android",
      "packageImportPath": "com.questionpro.interceptsdk.InterceptSdkPackage"
    },
    "ios": {
      "podspecPath": "./react-native-survey-intercept.podspec"
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
