{
  "name": "@questionpro/react-native-intercept-sdk",
  "version": "1.0.0",
  "description": "React Native SDK wrapper for QuestionPro Survey Intercept SDK",
  "main": "lib/commonjs/index.js",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index.ts",
  "scripts": {
    "prepare": "bob build",
    "build": "bob build",
    "example": "cd example && npm start"
  },
  "keywords": [
    "react-native",
    "questionpro", 
    "survey",
    "intercept"
  ],
  "repository": "https://github.com/questionpro/react-native-intercept-sdk",
  "author": "QuestionPro <support@questionpro.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.0.24",
    "@types/react-native": "0.70.6",
    "react": "18.2.0",
    "react-native": "0.72.4",
    "react-native-builder-bob": "^0.20.0",
    "typescript": "^4.8.4"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "react-native": {
    "android": {
      "sourceDir": "./android",
      "packageImportPath": "com.questionpro.interceptsdk.InterceptSdkPackage"
    },
    "ios": {
      "podspecPath": "./react-native-intercept-sdk.podspec"
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}